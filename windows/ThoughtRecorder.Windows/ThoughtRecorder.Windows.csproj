<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>ThoughtRecorder.Windows</RootNamespace>
    <AssemblyName>ThoughtRecorder</AssemblyName>
    <Version>1.0.0</Version>
    <Authors>Vessel Systems</Authors>
    <Company>Vessel Systems</Company>
    <Product>ThoughtRecorder</Product>
    <Description>A tiny Windows tray app for fast voice capture.</Description>
    <Copyright>Copyright Vessel Systems contributors</Copyright>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationHighDpiMode>PerMonitorV2</ApplicationHighDpiMode>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <SupportedOSPlatformVersion>10.0.19041.0</SupportedOSPlatformVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Speech" Version="8.0.0" />
  </ItemGroup>
</Project>
